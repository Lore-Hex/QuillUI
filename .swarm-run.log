+    public static let windowMinimizeYellow = PaintColor(r: 254, g: 188, b: 46)
+    public static let windowMaximizeGreen = PaintColor(r: 40, g: 200, b: 64)
+
+    /// Light-mode macOS titlebar background and bottom hairline.
