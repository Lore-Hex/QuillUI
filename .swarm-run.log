diff --git a/Tests/QuillPaintTests/MacWindowChromePaintTests.swift b/Tests/QuillPaintTests/MacWindowChromePaintTests.swift
new file mode 100644
index 0000000000000000000000000000000000000000..fdee2671b24b9228ed5c59f35cba6d835027eb4a
