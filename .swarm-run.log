+        case .minimize:
+            context.strokeLine(
+                from: PaintPoint(x: left, y: midY),
+                to: PaintPoint(x: right, y: midY),
+                color: color,
+                lineWidth: lineWidth
+            )
+
+        case .maximize:
+            context.strokeLine(
+                from: PaintPoint(x: left, y: midY),
+                to: PaintPoint(x: right, y: midY),
+                color: color,
+                lineWidth: lineWidth
+            )
+            context.strokeLine(
+                from: PaintPoint(x: midX, y: top),
+                to: PaintPoint(x: midX, y: bottom),
+                color: color,
+                lineWidth: lineWidth
+            )
+        }
+    }
+}
