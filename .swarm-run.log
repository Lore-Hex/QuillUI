+            #expect(radius == MacMetrics.WindowChrome.titleStubCornerRadius)
+            #expect(color == MacWindowChromePaint.titleStubColor)
+        } else {
+            Issue.record("Expected centered title placeholder as call 4, got \(ctx.calls[4])")
+        }
+    }
+}

