# Swarm worker temp files (written into the worktree by
# .swarm/spawn-non-claude-worker.sh; should never enter a PR).
.swarm-prompt.txt
.swarm-run.log

# QuillSignal UI screenshots (scripts/quill-signal-screenshot.sh) — local-only.
.qs-shot.png
.qs-qr-zoom.png

# Local smoke-test and debugging artifacts. Real checked-in screenshots should
# live under a named fixture or docs directory, not as root temp files.
.tmp-*
tmp-*

# Vendored SwiftPM dependency caches should contain buildable source, manifests,
# licenses, and resources. Keep upstream CI, local build products, tests, docs,
# and prebuilt archives out of the repository-level vendor cache.
